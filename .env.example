# ScodocAlert Configuration

# Scodoc Gateway URL
SCODOC_URL=https://scodoc.example.com

# CAS Authentication URL (optional, auto-detected from gateway)
CAS_URL=https://cas.example.com

# Your Scodoc credentials
SCODOC_USER=your_username
SCODOC_PASSWORD=your_password

# Discord Webhook URL for notifications
DISCORD_WEBHOOK_URL=your_webhook_url

# URL to the bulletin page (shown in Discord embeds)
BULLETIN_URL=https://......./login?service=... or something else

# SSL Certificate verification (True/False)
VERIFY_SSL=False

# Semester Selection
# -1 = dernier semestre (latest/most recent)
# -2 = avant-dernier semestre (second to last)
# 0 = premier semestre (first in list)
# 1 = deuxième semestre (second in list)
# 2 = troisième semestre (third in list)
# etc.
SEMESTER_INDEX=-2
